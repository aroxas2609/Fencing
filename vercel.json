{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path.html",
      "destination": "/:path",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "johnstonecivil.vercel.app" }],
      "destination": "https://johnstone-fencing.vercel.app/:path*",
      "permanent": true
    }
  ]
}
